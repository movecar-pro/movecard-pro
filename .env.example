# ============================================================
# Variables de entorno — copia este archivo a .env y ajústalo.
# Las PUBLIC_* quedan disponibles en el cliente (import.meta.env).
# ============================================================

# 🖼️  Imágenes: false = placeholders (default dev). true = sirve assets reales
#     desde /public/assets/images. Ver src/lib/config.ts y Placeholder.astro.
PUBLIC_USE_REAL_IMAGES=false

# 📊  Google Analytics 4. Vacío = no se inyecta tracking (dev/preview limpios).
#     Ej.: PUBLIC_GA_ID=G-XXXXXXXXXX
PUBLIC_GA_ID=

# 🏷️  Google Tag Manager. Vacío = NO se inyecta GTM.
#     Defínelo SOLO en producción (Vercel) para no medir el preview de stakeholders.
#     Ej.: PUBLIC_GTM_ID=GTM-XXXXXXX
PUBLIC_GTM_ID=

# 🌐  URL canónica del sitio (sitemap, canonical, Open Graph). Sin barra final.
#     Producción (Vercel): https://movecar.pro
PUBLIC_SITE_URL=https://movecar.pro

# 🔎  noindex. true = agrega <meta robots noindex> (úsalo en el preview de Netlify
#     para que el staging no se indexe). Vacío/false en producción.
PUBLIC_NOINDEX=
