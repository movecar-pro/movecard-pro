---
/**
 * FeatureItem — fila de feature con icono en tile redondeado + copy.
 * Portado del DS (components/cards/FeatureItem.jsx).
 * `icon`: clase Font Awesome (ej. "fa-solid fa-bolt").
 */
interface Props {
  icon: string;
  title: string;
  tone?: 'amber' | 'eco' | 'dark';
  layout?: 'row' | 'stack';
  class?: string;
}
const { icon, title, tone = 'amber', layout = 'row', class: className } = Astro.props;
const tones: Record<string, string> = {
  amber: 'background:var(--amber-50);color:var(--amber-600);',
  eco: 'background:var(--green-50);color:var(--green-700);',
  dark: 'background:var(--ink-700);color:var(--amber-400);',
};
const onDark = tone === 'dark';
const wrap = `display:flex;flex-direction:${layout === 'stack' ? 'column' : 'row'};gap:var(--space-4);align-items:flex-start;`;
const tile = `flex-shrink:0;width:48px;height:48px;border-radius:var(--radius-md);display:inline-flex;align-items:center;justify-content:center;font-size:20px;${tones[tone]}`;
const titleStyle = `font-family:var(--font-sans);font-weight:var(--fw-semibold);font-size:var(--fs-body-lg);color:${onDark ? 'var(--white)' : 'var(--text-strong)'};`;
const bodyStyle = `font-family:var(--font-sans);font-size:var(--fs-body);line-height:var(--lh-body);color:${onDark ? 'var(--white-a70)' : 'var(--text-muted)'};`;
---

<div class={className} style={wrap}>
  <span style={tile} aria-hidden="true"><i class={icon}></i></span>
  <div style="display:flex;flex-direction:column;gap:4px">
    <span style={titleStyle}>{title}</span>
    <span style={bodyStyle}><slot /></span>
  </div>
</div>
