---
/**
 * Movecar Button — CTA primario es amber sólido con glow.
 * Portado del DS (components/core/Button.jsx) a Astro estático.
 * Renderiza <a> si recibe `href`, si no <button>.
 *
 * Iconos: pasa una clase Font Awesome en `icon` (ej. "fa-solid fa-arrow-right").
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'dark' | 'light' | 'link';
  size?: 'sm' | 'md' | 'lg';
  icon?: string;
  iconPosition?: 'leading' | 'trailing';
  full?: boolean;
  href?: string;
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  icon,
  iconPosition = 'leading',
  full = false,
  href,
  disabled = false,
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  sm: { padding: '8px 18px', fontSize: '14px', gap: '8px', icon: '16px' },
  md: { padding: '13px 26px', fontSize: '16px', gap: '10px', icon: '18px' },
  lg: { padding: '17px 34px', fontSize: '17px', gap: '12px', icon: '20px' },
};
const s = sizes[size] ?? sizes.md;

const variants: Record<string, string> = {
  primary: 'background:var(--color-primary);color:var(--color-on-primary);box-shadow:var(--shadow-amber);',
  secondary: 'background:transparent;color:var(--text-strong);border-color:var(--border-strong);',
  dark: 'background:var(--ink-600);color:var(--white);',
  light: 'background:var(--white);color:var(--text-strong);box-shadow:var(--shadow-sm);',
  link: 'background:transparent;color:var(--text-accent);',
};

const isLink = variant === 'link';
const base = [
  `display:${full ? 'flex' : 'inline-flex'}`,
  `width:${full ? '100%' : 'auto'}`,
  'align-items:center',
  'justify-content:center',
  `gap:${s.gap}`,
  `padding:${isLink ? '0' : s.padding}`,
  'font-family:var(--font-sans)',
  'font-weight:var(--fw-semibold)',
  `font-size:${s.fontSize}`,
  'line-height:1.2',
  'letter-spacing:0.01em',
  `border-radius:${isLink ? '0' : 'var(--radius-sm)'}`,
  'border:1px solid transparent',
  `cursor:${disabled ? 'not-allowed' : 'pointer'}`,
  'text-decoration:none',
  'white-space:nowrap',
  'transition:background var(--dur-fast) var(--ease-out),color var(--dur-fast) var(--ease-out),border-color var(--dur-fast) var(--ease-out),box-shadow var(--dur-fast) var(--ease-out),transform var(--dur-fast) var(--ease-out)',
  `opacity:${disabled ? '0.5' : '1'}`,
].join(';');

const style = `${base};${variants[variant]}`;
const Tag = href ? 'a' : 'button';
---

<Tag
  class={className}
  style={style}
  href={href}
  type={href ? undefined : 'button'}
  disabled={!href && disabled ? true : undefined}
  data-variant={variant}
  {...rest}
>
  {icon && iconPosition === 'leading' && (
    <i class={icon} style={`font-size:${s.icon}`} aria-hidden="true"></i>
  )}
  {
    isLink ? (
      <span style="border-bottom:2px solid currentColor;padding-bottom:1px"><slot /></span>
    ) : (
      <slot />
    )
  }
  {icon && iconPosition === 'trailing' && (
    <i class={icon} style={`font-size:${s.icon}`} aria-hidden="true"></i>
  )}
</Tag>

<style>
  /* Estados hover/press de marca (color-only, sin scale) — readme del DS. */
  [data-variant='primary']:hover {
    background: var(--color-primary-hover) !important;
  }
  [data-variant='primary']:active {
    background: var(--color-primary-press) !important;
  }
  [data-variant='secondary']:hover {
    background: var(--ink-600) !important;
    color: var(--white) !important;
  }
  [data-variant='light']:hover {
    background: var(--grey-100) !important;
  }
  [data-variant='dark']:hover {
    background: var(--ink-700) !important;
  }
</style>
