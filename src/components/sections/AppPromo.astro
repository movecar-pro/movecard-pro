---
/**
 * AppPromo — panel charcoal redondeado con streaks: copy de la app +
 * mockup (placeholder) y botones de store.
 */
import Button from '@components/primitives/Button.astro';
import Streaks from '@components/decor/Streaks.astro';
import Placeholder from '@components/primitives/Placeholder.astro';
import { appPromo } from '@lib/content';

const storeIcon: Record<string, string> = { Apple: 'fa-brands fa-apple', Android: 'fa-brands fa-android' };
---

<section class="mc-section" style="background:var(--white)">
  <div class="mc-container">
    <div class="app" data-gsap="scale-in">
      <Streaks opacity={0.7} parallax />
      <div class="app__copy">
        <h2 class="app__title">{appPromo.title}</h2>
        <p class="app__body">{appPromo.body}</p>
        <div class="app__actions">
          <Button variant="dark" icon="fa-solid fa-download" href="#descargar">{appPromo.cta}</Button>
          <span class="app__stores">
            {
              appPromo.stores.map((s) => (
                <span class="app__store">
                  <i class={storeIcon[s]} aria-hidden="true" />
                  {s}
                </span>
              ))
            }
          </span>
        </div>
      </div>
      <div class="app__media">
        <Placeholder src={appPromo.image.src} alt={appPromo.image.alt} ratio="9/16" fit="cover" rounded="26px" />
      </div>
    </div>
  </div>
</section>

<style>
  .app {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: var(--ink-600);
    padding: 56px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
  }
  .app__copy {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .app__title {
    margin: 0;
    font-size: var(--fs-h2);
    color: var(--white);
  }
  .app__body {
    margin: 0;
    font-size: 17px;
    line-height: var(--lh-body);
    color: var(--white-a85);
    max-width: 440px;
  }
  .app__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .app__stores {
    display: flex;
    gap: 10px;
  }
  .app__store {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink-900);
    color: var(--white);
    border-radius: var(--radius-sm);
    padding: 10px 16px;
    font-size: 14px;
  }
  .app__media {
    position: relative;
    display: flex;
    justify-content: center;
    max-width: 240px;
    margin-inline: auto;
    box-shadow: var(--shadow-lg);
    border-radius: 26px;
  }
  @media (max-width: 900px) {
    .app {
      grid-template-columns: 1fr;
      padding: 32px;
      text-align: center;
    }
    .app__body {
      max-width: none;
    }
    .app__actions {
      justify-content: center;
    }
  }
</style>
