---
/**
 * FinalCTA — cierre con FONDO SÓLIDO ámbar y TEXTO OSCURO (como el diseño).
 * Sin streaks. CTA único. id="postular" → ancla destino de los CTAs.
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import { finalCta } from '@lib/content';

// Iconos por bullet (orden: Datos seguros · Sin spam · Cancelación libre).
const bulletIcons = ['fa-lock', 'fa-check', 'fa-shield-halved'];
---

<section class="final" id="postular">
  <div class="final__inner" data-gsap="fade-up">
    <Eyebrow tone="dark">{finalCta.eyebrow}</Eyebrow>
    <h2 class="final__title">{finalCta.title}</h2>
    <p class="final__body">{finalCta.body}</p>
    <div class="final__cta">
      <Button size="lg" href="#postular">{finalCta.cta}</Button>
    </div>
    <div class="final__bullets">
      {
        finalCta.bullets.map((t, i) => (
          <span class="final__bullet">
            <i class={`fa-solid ${bulletIcons[i] ?? 'fa-circle-check'}`} aria-hidden="true" />
            {t}
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .final {
    /* Fondo sólido ámbar, texto oscuro. */
    background: var(--amber-400);
    padding-block: 88px;
    text-align: center;
  }
  .final__inner {
    max-width: 720px;
    margin: 0 auto;
    padding-inline: var(--page-gutter);
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }
  .final__title {
    margin: 0;
    font-size: var(--fs-h1);
    line-height: 1.1;
    color: var(--ink-800);
  }
  .final__body {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--ink-600);
  }
  .final__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .final__bullets {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 6px;
  }
  .final__bullet {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ink-700);
  }
  .final__bullet i {
    color: var(--ink-600);
  }
</style>
