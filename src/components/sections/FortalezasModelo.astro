---
/**
 * FortalezasModelo — "Fortalezas de Nuestro Modelo": auto en vista superior
 * al centro, 3 features a cada lado (la columna derecha en espejo). Iconos en
 * círculo blanco. Fondo de marca streak2.svg.
 * En móvil: título → auto → features en una sola columna (todo a la izquierda).
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Placeholder from '@components/primitives/Placeholder.astro';
import { fortalezas } from '@lib/content';

const left = fortalezas.items.slice(0, 3);
const right = fortalezas.items.slice(3, 6);
---

<section class="fm">
  <div class="fm__inner mc-container">
    <div class="fm__head" data-gsap="fade-up">
      <Eyebrow align="center" tone="dark">{fortalezas.eyebrow}</Eyebrow>
      <h2 class="fm__title">{fortalezas.title}</h2>
    </div>

    <div class="fm__grid">
      <div class="fm__col" data-gsap="fade-right">
        {
          left.map((f) => (
            <div class="fm__feat">
              <span class="fm__feat-icon" aria-hidden="true">
                <i class={`fa-solid ${f.icon}`} />
              </span>
              <div class="fm__feat-text">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="fm__car" data-gsap="scale-in">
        <Placeholder
          src={fortalezas.carImage.src}
          alt={fortalezas.carImage.alt}
          ratio="3/5"
          fit="contain"
          rounded="0"
        />
      </div>

      <div class="fm__col fm__col--right" data-gsap="fade-left">
        {
          right.map((f) => (
            <div class="fm__feat">
              <span class="fm__feat-icon" aria-hidden="true">
                <i class={`fa-solid ${f.icon}`} />
              </span>
              <div class="fm__feat-text">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .fm {
    position: relative;
    overflow: hidden;
    /* Fondo de marca. SVG en public/assets/images/backgrounds/streak2.svg */
    background:
      url('/assets/images/backgrounds/streak2.svg') center / cover no-repeat,
      #fff6e6;
    padding-block: var(--space-section);
  }
  .fm__inner {
    position: relative;
  }
  .fm__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 8px;
  }
  .fm__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .fm__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .fm__col {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .fm__car {
    display: flex;
    justify-content: center;
    max-width: 380px;
    margin-inline: auto;
  }

  /* Feature: icono en círculo blanco + texto */
  .fm__feat {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .fm__feat-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-pill);
    background: var(--white);
    color: var(--ink-700);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    box-shadow: var(--shadow-sm);
  }
  .fm__feat-text h3 {
    margin: 0 0 6px;
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-body-lg);
    color: var(--text-strong);
  }
  .fm__feat-text p {
    margin: 0;
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* Columna derecha: en espejo (texto a la derecha, icono a la derecha) */
  .fm__col--right .fm__feat {
    flex-direction: row-reverse;
    text-align: right;
  }

  @media (max-width: 900px) {
    .fm__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .fm__car {
      order: -1;
      max-width: 300px;
    }
    .fm__col {
      gap: 28px;
    }
    /* En móvil todo alineado a la izquierda (sin espejo) */
    .fm__col--right .fm__feat {
      flex-direction: row;
      text-align: left;
    }
  }
</style>
