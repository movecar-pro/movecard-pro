---
/**
 * Hero — banda charcoal con motion-streaks, titular money-first y vehículo.
 * data-anim="hero" + data-gsap="hero-*" → la timeline secuenciada de
 * lib/animations/choreography.ts anima esta sección al cargar.
 */
import { getCollection } from 'astro:content';
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import HeroCarousel from '@components/islands/HeroCarousel.tsx';
import { hero, WHATSAPP_URL } from '@lib/content';

// 3 modelos para el carrusel del hero (desde la colección `fleet`).
const heroCars = (await getCollection('fleet'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)
  .map((v) => ({ src: v.data.image, alt: v.data.name }));
---

<header class="hero" data-anim="hero">
  <div class="hero__inner mc-container">
    <div class="hero__copy">
      <Eyebrow tone="muted" data-gsap="hero-eyebrow">{hero.eyebrow}</Eyebrow>
      <h1 class="hero__title" data-gsap="hero-title">
        {hero.titleLead}
        <span class="hero__hl">{hero.titleHighlight}</span>
        {hero.titleRest}
      </h1>
      <p class="hero__subtitle" data-gsap="hero-subtitle">{hero.subtitle}</p>
      <div class="hero__cta" data-gsap="hero-cta">
        <Button
          size="lg"
          class="uppercase"
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer">{hero.ctaPrimary}</Button
        >
        <Button size="lg" variant="secondary" class="uppercase" href="#como-funciona"
          >{hero.ctaSecondary}</Button
        >
      </div>
      <div class="hero__bullets">
        {
          hero.bullets.map((t) => (
            <span class="hero__bullet" data-gsap="hero-bullet">
              <i class="fa-solid fa-circle-check" style="color:var(--amber-500)" />
              {t}
            </span>
          ))
        }
      </div>
    </div>

    {/* Carrusel transparente auto-rotatorio (oculto en móvil vía CSS) */}
    <div class="hero__media" data-gsap="hero-media">
      <HeroCarousel client:idle items={heroCars} />
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    /* Fondo de marca (streaks ámbar sobre claro). El SVG se agrega en
       public/assets/images/backgrounds/streak1.svg */
    background: var(--white) url('/assets/images/backgrounds/streak1.svg') center / cover no-repeat;
    overflow: hidden;
  }
  .hero__inner {
    position: relative;
    padding-block: 84px 96px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 40px;
    align-items: center;
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 26px;
    max-width: 560px;
  }
  .hero__title {
    margin: 0;
    font-size: var(--fs-display);
    line-height: 1.08;
    color: var(--text-strong);
  }
  .hero__hl {
    color: var(--amber-500);
  }
  .hero__subtitle {
    margin: 0;
    font-size: var(--fs-lead);
    line-height: 1.55;
    color: var(--text-muted);
  }
  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero__bullets {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .hero__bullet {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-body);
  }
  /* Tablet/mobile: una sola columna. El carrusel del auto se OCULTA. */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero__copy {
      max-width: none;
    }
    .hero__media {
      display: none;
    }
  }
</style>
