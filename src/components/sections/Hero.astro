---
/**
 * Hero — banda charcoal con motion-streaks, titular money-first y vehículo.
 * data-anim="hero" + data-gsap="hero-*" → la timeline secuenciada de
 * lib/animations/choreography.ts anima esta sección al cargar.
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import Streaks from '@components/decor/Streaks.astro';
import Placeholder from '@components/primitives/Placeholder.astro';
import { hero } from '@lib/content';
---

<header class="hero" data-anim="hero">
  <Streaks opacity={0.85} />
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__inner mc-container">
    <div class="hero__copy">
      <Eyebrow tone="onDark" data-gsap="hero-eyebrow">{hero.eyebrow}</Eyebrow>
      <h1 class="hero__title" data-gsap="hero-title">
        {hero.titleLead} <span class="hero__hl">{hero.titleHighlight}</span> {hero.titleRest}
      </h1>
      <p class="hero__subtitle" data-gsap="hero-subtitle">{hero.subtitle}</p>
      <div class="hero__cta" data-gsap="hero-cta">
        <Button size="lg" href="#postular">{hero.ctaPrimary}</Button>
        <Button size="lg" variant="light" href="#como-funciona">{hero.ctaSecondary}</Button>
      </div>
      <div class="hero__bullets">
        {
          hero.bullets.map((t) => (
            <span class="hero__bullet" data-gsap="hero-bullet">
              <i class="fa-solid fa-circle-check" style="color:var(--amber-500)" />
              {t}
            </span>
          ))
        }
      </div>
    </div>

    <div class="hero__media" data-gsap="hero-media">
      <Placeholder src={hero.image.src} alt={hero.image.alt} ratio="4/3" fit="contain" rounded="var(--radius-lg)" />
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    background: var(--ink-600);
    overflow: hidden;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(51, 51, 51, 0.96) 0%,
      rgba(51, 51, 51, 0.78) 48%,
      rgba(51, 51, 51, 0.25) 100%
    );
  }
  .hero__inner {
    position: relative;
    padding-block: 84px 96px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 40px;
    align-items: center;
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 26px;
    max-width: 560px;
  }
  .hero__title {
    margin: 0;
    font-size: var(--fs-display);
    line-height: 1.08;
    color: var(--white);
  }
  .hero__hl {
    color: var(--amber-500);
  }
  .hero__subtitle {
    margin: 0;
    font-size: var(--fs-lead);
    line-height: 1.55;
    color: var(--white-a70);
  }
  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero__bullets {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .hero__bullet {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--white-a85);
  }
  .hero__media :global(div),
  .hero__media :global(img) {
    filter: drop-shadow(0 30px 50px rgba(0, 0, 0, 0.45));
  }

  /* Tablet/mobile: una sola columna, media debajo del copy. */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero__scrim {
      background: rgba(51, 51, 51, 0.82);
    }
    .hero__copy {
      max-width: none;
    }
    .hero__media {
      order: -1;
      max-width: 420px;
    }
  }
</style>
