---
/**
 * NosotrosHero — sección 1 de /nosotros: título con palabra en ámbar, copy y
 * CTA a la izquierda; mosaico de rostros a la derecha (mix-blend-mode:multiply
 * para fundirse con el fondo). Fondo base: backgrounds/nosotros.webp.
 */
import Button from '@components/primitives/Button.astro';
import { about } from '@lib/content';
import { IMAGE_BASE } from '@lib/config';
const h = about.hero;
const bgUrl = `${IMAGE_BASE}/${h.bg}`;
const mosaicUrl = `${IMAGE_BASE}/${h.image.src}`;
---

<header class="nh" data-anim="hero" style={`background-image:url('${bgUrl}')`}>
  {/* Velo claro a la izquierda para legibilidad del texto oscuro */}
  <div class="nh__veil" aria-hidden="true"></div>

  <div class="nh__inner mc-container">
    <div class="nh__copy">
      <h1 class="nh__title" data-gsap="hero-title">
        {h.titleLead}
        <span class="nh__hl">{h.titleHighlight}</span><br />
        {h.titleRest}
      </h1>
      <div class="nh__body" data-gsap="hero-subtitle">
        {h.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div data-gsap="hero-cta"><Button size="lg" href="#postular">{h.cta}</Button></div>
    </div>

    {
      /* Mosaico de rostros — funde con el fondo vía multiply.
        Archivo: public/assets/images/team/team-mosaic.webp */
    }
    <div class="nh__media">
      <img class="nh__mosaic" src={mosaicUrl} alt={h.image.alt} loading="lazy" />
    </div>
  </div>
</header>

<style>
  .nh {
    position: relative;
    overflow: hidden;
    background-color: var(--surface-subtle);
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    /* Contiene el blending: el mosaico (multiply) se funde con ESTE fondo. */
    isolation: isolate;
  }
  /* Velo cálido (izq → der) para contraste del texto sin tapar el mosaico. */
  .nh__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(255, 250, 242, 0.6) 0%,
      rgba(255, 250, 242, 0.2) 40%,
      rgba(255, 250, 242, 0) 65%
    );
  }
  .nh__inner {
    position: relative;
    /* Sin z-index: evita crear un stacking context que aísle el blending.
       El contenido igual queda sobre el velo por orden de pintado. */
    padding-block: 72px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: center;
  }
  .nh__copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 520px;
  }
  .nh__title {
    margin: 0;
    font-size: var(--fs-display);
    line-height: 1.08;
    color: var(--text-strong);
  }
  .nh__hl {
    color: var(--amber-500);
  }
  .nh__body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .nh__body p {
    margin: 0;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--text-muted);
  }
  .nh__media {
    position: relative;
  }
  .nh__mosaic {
    display: block;
    width: 100%;
    height: auto;
    /* Funde el mosaico con el fondo (los blancos desaparecen). */
    mix-blend-mode: multiply;
  }

  @media (max-width: 900px) {
    .nh__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .nh__copy {
      max-width: none;
    }
    /* En móvil el mosaico no se muestra (el diseño es solo texto). */
    .nh__media {
      display: none;
    }
  }
</style>
