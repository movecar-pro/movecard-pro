---
/**
 * Pasos — proceso de inscripción con StepTrail (línea conectada numerada).
 * StepTrail está inline aquí (no es interactivo) usando los tokens del DS.
 * Cada paso entra con stagger.
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import { pasos, WHATSAPP_URL } from '@lib/content';
---

<section class="mc-section" style="background:var(--white)">
  <div class="pasos mc-container">
    <div class="pasos__copy" data-gsap="fade-right">
      <Eyebrow>{pasos.eyebrow}</Eyebrow>
      <h2 class="pasos__title">{pasos.title}</h2>
      <p class="pasos__body">{pasos.body}</p>
      <div>
        <Button href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="uppercase"
          >{pasos.cta}</Button
        >
      </div>
    </div>

    <ol class="trail" data-gsap-group>
      {
        pasos.steps.map((s, i) => (
          <li class="trail__item" data-gsap-child>
            <div class="trail__rail">
              <span class="trail__num">{i + 1}</span>
              {i < pasos.steps.length - 1 && <span class="trail__line" />}
            </div>
            <div class="trail__content">
              <span class="trail__day">{s.day}</span>
              <span class="trail__t">{s.title}</span>
              <span class="trail__b">{s.body}</span>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .pasos {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 64px;
    align-items: start;
  }
  .pasos__copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .pasos__title {
    margin: 0;
    font-size: var(--fs-h1);
    line-height: 1.12;
    color: var(--text-strong);
  }
  .pasos__body {
    margin: 0;
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    color: var(--text-muted);
  }
  .trail {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .trail__item {
    display: flex;
    gap: var(--space-4);
  }
  .trail__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .trail__num {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    background: var(--amber-500);
    color: var(--white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: 16px;
    box-shadow: var(--shadow-amber);
  }
  .trail__line {
    flex: 1;
    width: 2px;
    background: var(--border-subtle);
    margin: 6px 0;
    min-height: 24px;
  }
  .trail__content {
    padding-bottom: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .trail__item:last-child .trail__content {
    padding-bottom: 0;
  }
  .trail__day {
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    font-size: 12px;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-accent);
  }
  .trail__t {
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-body-lg);
    color: var(--text-strong);
  }
  .trail__b {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--text-muted);
  }
  @media (max-width: 900px) {
    .pasos {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
