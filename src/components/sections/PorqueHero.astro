---
/**
 * PorqueHero — sección 1 de /como-funciona. Fondo a sangre completa con la
 * imagen base how-to.webp (foto de conductor con tratamiento ámbar). Texto
 * OSCURO sobre un velo claro a la izquierda para legibilidad. Título, copy,
 * CTAs y los 3 bullets de confianza. data-anim/data-gsap → timeline del hero.
 */
import Button from '@components/primitives/Button.astro';
import { comoFunciona, WHATSAPP_URL } from '@lib/content';
const { title, subtitle, ctaPrimary, ctaSecondary, bullets } = comoFunciona.hero;

// Iconos por bullet (shield · check · star), como el diseño.
const bulletIcons = ['fa-shield-halved', 'fa-check', 'fa-star'];
---

<header class="ph2" data-anim="hero">
  {/* Velo claro a la izquierda para que el texto oscuro sea legible */}
  <div class="ph2__veil" aria-hidden="true"></div>

  <div class="ph2__inner mc-container">
    <div class="ph2__copy">
      <h1 class="ph2__title" data-gsap="hero-title">{title}</h1>
      <p class="ph2__subtitle" data-gsap="hero-subtitle">{subtitle}</p>
      <div class="ph2__cta" data-gsap="hero-cta">
        <Button size="lg" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="uppercase"
          >{ctaPrimary}</Button
        >
        <Button size="lg" variant="secondary" href="#como-funciona" class="uppercase"
          >{ctaSecondary}</Button
        >
      </div>
      <div class="ph2__bullets">
        {
          bullets.map((t, i) => (
            <span class="ph2__bullet" data-gsap="hero-bullet">
              <i class={`fa-solid ${bulletIcons[i] ?? 'fa-circle-check'}`} aria-hidden="true" />
              {t}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</header>

<style>
  .ph2 {
    position: relative;
    overflow: hidden;
    /* Imagen base. Archivo: public/assets/images/backgrounds/how-to.webp */
    background: var(--grey-50) url('/assets/images/backgrounds/how-to.webp') center / cover
      no-repeat;
  }
  /* Velo claro (izq → der) para contraste del texto oscuro. */
  .ph2__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(255, 250, 242, 0.82) 0%,
      rgba(255, 250, 242, 0.45) 42%,
      rgba(255, 250, 242, 0) 72%
    );
  }
  .ph2__inner {
    position: relative;
    padding-block: 110px;
  }
  .ph2__copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 520px;
  }
  .ph2__title {
    margin: 0;
    font-size: var(--fs-display);
    line-height: 1.08;
    color: var(--ink-800);
  }
  .ph2__subtitle {
    margin: 0;
    font-size: var(--fs-lead);
    line-height: 1.55;
    color: var(--ink-600);
  }
  .ph2__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .ph2__bullets {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .ph2__bullet {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ink-700);
  }
  .ph2__bullet i {
    color: var(--ink-700);
  }
  @media (max-width: 768px) {
    .ph2__inner {
      padding-block: 64px;
    }
    .ph2__veil {
      background: rgba(255, 250, 242, 0.7);
    }
    .ph2__bullets {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
