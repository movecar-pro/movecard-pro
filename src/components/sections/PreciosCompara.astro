---
/**
 * PreciosCompara — "Asegura el mejor plan para lo que necesitas": tabla
 * comparativa de los 4 planes. En móvil la primera columna queda fija y la
 * tabla hace scroll horizontal, mostrando ~2 columnas a la vez.
 * Reutiliza Eyebrow. Estático (sin JS).
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Streaks from '@components/decor/Streaks.astro';
import { pricing } from '@lib/content';
const { eyebrow, title, subtitle, plans, rows } = pricing.compare;
---

<section class="cmp">
  <Streaks color="var(--amber-200)" opacity={0.4} parallax />
  <div class="cmp__inner mc-container">
    <div class="cmp__head" data-gsap="fade-up">
      <Eyebrow align="center">{eyebrow}</Eyebrow>
      <h2 class="cmp__title">{title}</h2>
      <p class="cmp__subtitle">{subtitle}</p>
    </div>

    <div class="cmp__scroll" data-gsap="fade-up">
      <table class="cmp__table">
        <thead>
          <tr>
            <th class="cmp__rowhead" scope="col"><span class="cmp__sr">Característica</span></th>
            {
              plans.map((p) => (
                <th scope="col" class="cmp__plan">
                  <i
                    class={`fa-solid ${p.fuel === 'ev' ? 'fa-bolt' : 'fa-gas-pump'}`}
                    style={`color:${p.fuel === 'ev' ? 'var(--amber-500)' : 'var(--ink-500)'}`}
                    aria-hidden="true"
                  />
                  <span>{p.name}</span>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) => (
              <tr>
                <th scope="row" class="cmp__rowhead">{r.label}</th>
                {r.values.map((v) => (
                  <td>
                    {v === true ? (
                      <i class="fa-solid fa-check cmp__yes" aria-label="Incluido" />
                    ) : v === false ? (
                      <i class="fa-solid fa-minus cmp__no" aria-label="No incluido" />
                    ) : (
                      <span class="cmp__val">{v}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="cmp__hint">Desliza para comparar todos los planes →</p>
  </div>
</section>

<style>
  .cmp {
    position: relative;
    overflow: hidden;
    background: var(--white);
    padding-block: var(--space-section);
  }
  .cmp__inner {
    position: relative;
  }
  .cmp__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
    margin: 0 auto 44px;
  }
  .cmp__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .cmp__subtitle {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--text-muted);
  }

  .cmp__scroll {
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
  }
  .cmp__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }
  .cmp__table th,
  .cmp__table td {
    padding: 16px 20px;
    text-align: center;
    border-bottom: 1px solid var(--border-subtle);
    font-size: var(--fs-small);
  }
  .cmp__table tbody tr:last-child th,
  .cmp__table tbody tr:last-child td {
    border-bottom: none;
  }
  /* primera columna (etiquetas) fija y alineada a la izquierda */
  .cmp__rowhead {
    position: sticky;
    left: 0;
    z-index: 1;
    text-align: left;
    background: var(--surface-subtle);
    font-weight: var(--fw-semibold);
    color: var(--text-strong);
    min-width: 200px;
  }
  thead .cmp__plan {
    background: var(--white);
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    color: var(--text-strong);
    white-space: nowrap;
  }
  thead .cmp__plan {
    display: table-cell;
  }
  thead .cmp__plan i {
    margin-right: 6px;
  }
  thead th {
    border-bottom: 2px solid var(--border-subtle);
  }
  .cmp__yes {
    color: var(--green-700);
  }
  .cmp__no {
    color: var(--grey-300);
  }
  .cmp__val {
    color: var(--text-body);
    font-weight: var(--fw-medium);
  }
  .cmp__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  .cmp__hint {
    display: none;
    margin: 12px 0 0;
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
  }

  /* En móvil mostramos la pista de scroll (la 1ª col fija deja ~2 visibles). */
  @media (max-width: 900px) {
    .cmp__hint {
      display: block;
    }
    .cmp__rowhead {
      min-width: 150px;
    }
  }
</style>
