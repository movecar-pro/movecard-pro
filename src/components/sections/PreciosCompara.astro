---
/**
 * PreciosCompara — "Asegura el mejor plan para lo que necesitas": tabla
 * comparativa MoveCar vs. competencia. Cada columna lleva una IMAGEN circular
 * en el encabezado. En móvil solo se muestran 2 columnas: Beneficio + MoveCar
 * (las columnas de competidores se ocultan). Estático (sin JS).
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import { pricing } from '@lib/content';
import { IMAGE_BASE } from '@lib/config';
const { eyebrow, title, subtitle, rowHead, plans, rows } = pricing.compare;
---

<section class="cmp">
  <div class="cmp__inner mc-container">
    <div class="cmp__head" data-gsap="fade-up">
      <Eyebrow align="center">{eyebrow}</Eyebrow>
      <h2 class="cmp__title">{title}</h2>
      <p class="cmp__subtitle">{subtitle}</p>
    </div>

    <div class="cmp__scroll" data-gsap="fade-up">
      <table class="cmp__table">
        <thead>
          <tr>
            <th class="cmp__rowhead" scope="col">{rowHead}</th>
            {
              plans.map((p, i) => (
                <th scope="col" class={`cmp__plan ${i > 0 ? 'cmp__plan--rival' : ''}`}>
                  <span class="cmp__plan-img">
                    <img src={`${IMAGE_BASE}/${p.img}`} alt={p.name} loading="lazy" />
                  </span>
                  {p.brand && <span class="cmp__plan-name">{p.name}</span>}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) => (
              <tr>
                <th scope="row" class="cmp__rowhead">{r.label}</th>
                {r.values.map((v, i) => (
                  <td class={i > 0 ? 'cmp__cell--rival' : ''}>
                    {v === true ? (
                      <i class="fa-solid fa-check cmp__yes" aria-label="Incluido" />
                    ) : v === false ? (
                      <i class="fa-solid fa-xmark cmp__no" aria-label="No incluido" />
                    ) : (
                      <span class="cmp__val">{v}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .cmp {
    position: relative;
    overflow: hidden;
    /* Fondo de marca (streaks ámbar). */
    background:
      url('/assets/images/backgrounds/streak2a.svg') center / cover no-repeat,
      var(--white);
    padding-block: var(--space-section);
  }
  .cmp__inner {
    position: relative;
  }
  .cmp__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
    margin: 0 auto 44px;
  }
  .cmp__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .cmp__subtitle {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--text-muted);
  }

  .cmp__scroll {
    overflow-x: auto;
  }
  .cmp__table {
    width: 100%;
    border-collapse: collapse;
  }
  .cmp__table th,
  .cmp__table td {
    padding: 18px 20px;
    text-align: center;
    border-bottom: 1px solid var(--border-subtle);
    font-size: var(--fs-small);
    white-space: pre-line; /* permite saltos de línea en los valores */
    vertical-align: middle;
  }
  /* primera columna (etiquetas), alineada a la izquierda */
  .cmp__rowhead {
    text-align: left;
    font-weight: var(--fw-semibold);
    color: var(--text-strong);
    white-space: normal;
    min-width: 190px;
  }
  /* Encabezados con imagen circular */
  thead th {
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: bottom;
    padding-bottom: 22px;
  }
  thead .cmp__rowhead {
    vertical-align: bottom;
    font-weight: var(--fw-bold);
  }
  .cmp__plan-img {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cmp__plan-img img {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-pill);
    object-fit: cover;
    box-shadow: var(--shadow-sm);
  }
  .cmp__plan-name {
    display: block;
    margin-top: 10px;
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    color: var(--text-accent);
  }
  /* Columnas de competidores: leve tinte para resaltar MoveCar */
  .cmp__plan--rival,
  .cmp__cell--rival {
    background: rgba(254, 147, 7, 0.06);
  }
  .cmp__yes {
    color: var(--green-600);
    font-size: 16px;
  }
  .cmp__no {
    color: #e5484d;
    font-size: 16px;
  }
  .cmp__val {
    color: var(--text-body);
    font-weight: var(--fw-medium);
  }

  /* ---- MÓVIL: solo 2 columnas (Beneficio + MoveCar) ---- */
  @media (max-width: 900px) {
    .cmp__plan--rival,
    .cmp__cell--rival {
      display: none;
    }
    .cmp__rowhead {
      min-width: 0;
      width: 55%;
    }
    .cmp__table th,
    .cmp__table td {
      padding: 16px 12px;
    }
  }
</style>
