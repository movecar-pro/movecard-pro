---
/**
 * Testimonios — carrusel de testimonios (3 por pasada en desktop, 1 a 1 en
 * móvil). El shell (header) es estático; el carrusel es una isla escalable
 * (TestimoniosCarousel) que se alimenta de testimonios.items.
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import TestimoniosCarousel from '@components/islands/TestimoniosCarousel.tsx';
import { testimonios } from '@lib/content';
---

<section class="mc-section tst">
  <div class="mc-container">
    <div class="tst__head" data-gsap="fade-up">
      <Eyebrow align="center">{testimonios.eyebrow}</Eyebrow>
      <h2 class="tst__title">{testimonios.title}</h2>
      <p class="tst__body">{testimonios.body}</p>
      <p class="tst__star">
        <i class="fa-solid fa-star"></i>
        <i class="fa-solid fa-star"></i>
        <i class="fa-solid fa-star"></i>
        <i class="fa-solid fa-star"></i>
        <i class="fa-solid fa-star"></i>
      </p>
      <p class="tst__star-text">{testimonios.startext}</p>
    </div>

    <div data-gsap="fade-up">
      <TestimoniosCarousel client:visible items={testimonios.items} />
    </div>
  </div>
</section>

<style>
  .tst {
    /* Fondo de marca. SVG en public/assets/images/backgrounds/streak2.svg */
    background: var(--grey-50) url('/assets/images/backgrounds/streak2.svg') center / cover
      no-repeat;
  }
  .tst__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 44px;
  }
  .tst__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .tst__body {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--text-muted);
  }
  .tst__star {
    color: var(--color-orange-500);
  }
</style>
