---
/**
 * VentajasMovecar — "Muévete al futuro de la Electromovilidad" + 5 ventajas.
 * DESKTOP: grilla de 5 tarjetas (icono en círculo punteado), con un auto
 * tenue de fondo. MÓVIL: carrusel con dots (isla VentajasCarousel).
 * El shell (fondo, header, CTA) es estático; solo las tarjetas/carrusel
 * son isla. Reutiliza Eyebrow y Button.
 */
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import VentajasCarousel from '@components/islands/VentajasCarousel.tsx';
import { ventajasMovecar, WHATSAPP_URL } from '@lib/content';
const { eyebrow, title, subtitle, items, cta } = ventajasMovecar;
---

<section class="vm2 mc-section">
  <div class="vm2__inner mc-container">
    <div class="vm2__head" data-gsap="fade-up">
      <Eyebrow align="center">{eyebrow}</Eyebrow>
      <h2 class="vm2__title">{title}</h2>
      <p class="vm2__subtitle">{subtitle}</p>
    </div>

    {/* Tarjetas (grilla desktop · carrusel móvil con dots) */}
    <div data-gsap="fade-up">
      <VentajasCarousel client:visible items={items} />
    </div>

    <div class="vm2__cta">
      <Button href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="uppercase"
        >{cta}</Button
      >
    </div>
  </div>
</section>

<style>
  .vm2 {
    position: relative;
    overflow: hidden;
    /* Fondo de marca. SVG en public/assets/images/backgrounds/streak2a.svg */
    background: var(--surface-subtle) url('/assets/images/backgrounds/streak2a.svg') center / cover
      no-repeat;
  }
  .vm2__inner {
    position: relative;
    z-index: 1;
  }
  .vm2__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
    margin: 0 auto 48px;
  }
  .vm2__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .vm2__subtitle {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--text-muted);
  }
  .vm2__cta {
    text-align: center;
    margin-top: 44px;
  }
</style>
