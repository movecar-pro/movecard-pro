---
/**
 * ============================================================
 * PÁGINA DE EJEMPLO — patrón para escalar el sitio.
 * ------------------------------------------------------------
 * El prefijo "_" hace que Astro NO genere ruta para este archivo
 * (no se publica). Es solo una guía. Para crear una página real
 * (ej. /nosotros), copia este esqueleto a `nosotros.astro`.
 *
 * Demuestra:
 *   · Uso de BaseLayout con title/description/active propios.
 *   · Composición de primitivas del DS.
 *   · Una isla React (PlanAccordion) con client:visible.
 *   · El mismo sistema de animación on-scroll (data-gsap).
 * ============================================================
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Eyebrow from '@components/primitives/Eyebrow.astro';
import PlanAccordion from '@components/islands/PlanAccordion.tsx';
import type { AccordionEntry } from '@components/islands/PlanAccordion.tsx';

const faqs: AccordionEntry[] = [
  {
    title: '¿Necesito tener auto propio?',
    subtitle: 'Requisitos',
    content: 'No. Movecar te entrega el vehículo eléctrico con seguro, mantención y carga incluidos.',
  },
  {
    title: '¿Cuánto puedo ganar?',
    content: 'Depende de tu disponibilidad. Usa el simulador de la home para una estimación según tus días y horas.',
  },
  {
    title: '¿Qué pasa si el auto falla?',
    content: 'Te entregamos un vehículo de reemplazo en menos de 24 horas para que no dejes de generar ingresos.',
  },
];
---

<BaseLayout
  title="Preguntas frecuentes — Move Card Pro"
  description="Resuelve tus dudas sobre cómo generar ingresos con Movecar."
  active="Nosotros"
>
  <main class="mc-section">
    <div class="mc-container" style="max-width:var(--content-max)">
      <div style="text-align:center;display:flex;flex-direction:column;gap:12px;margin-bottom:40px" data-gsap="fade-up">
        <Eyebrow align="center">Preguntas frecuentes</Eyebrow>
        <h1 style="margin:0;font-size:var(--fs-h1);color:var(--text-strong)">Todo lo que necesitas saber</h1>
      </div>

      {/* 🏝️ Isla React hidratada al entrar en viewport. */}
      <div data-gsap="fade-up">
        <PlanAccordion client:visible items={faqs} />
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { initHomeChoreography } from '@lib/animations/choreography';
  initHomeChoreography();
</script>
