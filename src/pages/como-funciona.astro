---
/**
 * /como-funciona — replica la estructura exacta del diseño de referencia,
 * componiendo secciones del proyecto:
 *   1. PorqueHero            → hero "¿Porqué MOVECAR es tu mejor opción?"
 *   2. ComoFuncionaSteps     → stepper horizontal "Cómo Funciona" (01–04)
 *   3. Pasos                 → "Inscríbete fácil" (StepTrail, reutilizado)
 *   4. VentajasMovecar       → 5 ventajas (carrusel en móvil)
 *   5. Flota                 → carrusel de modelos (1 por vista en móvil)
 *   6. FortalezasModelo      → auto en vista superior + features
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PorqueHero from '@components/sections/PorqueHero.astro';
import Pasos from '@components/sections/Pasos.astro';
import Simulador from '@components/sections/Simulador.astro';
import VentajasMovecar from '@components/sections/VentajasMovecar.astro';
import Flota from '@components/sections/Flota.astro';
import FortalezasModelo from '@components/sections/FortalezasModelo.astro';
import { comoFunciona } from '@lib/content';
---

<BaseLayout
  title="Cómo funciona — MoveCar Pro"
  description={comoFunciona.hero.subtitle}
  active="Cómo Funciona"
>
  <main>
    <PorqueHero />
    <VentajasMovecar />
    <Pasos />
    <Flota />
    <!-- s -->
    <Simulador />
    <FortalezasModelo />
  </main>
</BaseLayout>

<script>
  import { initHomeChoreography } from '@lib/animations/choreography';
  initHomeChoreography();
</script>
