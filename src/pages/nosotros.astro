---
/**
 * /nosotros — página "Nosotros".
 * Patrón de escalado: PageHeader reutilizable + secciones compuestas con
 * primitivas del DS + reutilización de FinalCTA. Misma coreografía GSAP.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/sections/PageHeader.astro';
import Equipo from '@components/sections/Equipo.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import Card from '@components/primitives/Card.astro';
import StatBlock from '@components/cards/StatBlock.astro';
import FeatureItem from '@components/cards/FeatureItem.astro';
import Placeholder from '@components/primitives/Placeholder.astro';
import { about } from '@lib/content';
---

<BaseLayout
  title="Nosotros — Move Card Pro"
  description={about.header.subtitle}
  active="Nosotros"
>
  <main>
    <PageHeader {...about.header} />

    {/* Equipo va en segundo lugar (abre TeamModal al hacer clic en una tarjeta) */}
    <Equipo />

    {/* Misión: copy + imagen lifestyle */}
    <section class="mc-section" style="background:var(--white)">
      <div class="mision mc-container">
        <div class="mision__copy" data-gsap="fade-right">
          <Eyebrow>{about.mision.eyebrow}</Eyebrow>
          <h2 class="mision__title">{about.mision.title}</h2>
          <p class="mision__body">{about.mision.body}</p>
          <div style="display:flex;flex-direction:column;gap:10px">
            {
              about.mision.highlights.map((t) => (
                <span class="mision__hl">
                  <i class="fa-solid fa-check" style="color:var(--green-700)" />
                  {t}
                </span>
              ))
            }
          </div>
          <div><Button href="#postular">{about.mision.cta}</Button></div>
        </div>
        <div class="mision__media" data-gsap="fade-left">
          <Placeholder src="lifestyle/driver.png" alt="Movedriver Movecar" ratio="4/5" fit="cover" rounded="var(--radius-lg)" />
        </div>
      </div>
    </section>

    {/* Stats */}
    <section style="background:var(--grey-50);padding-block:var(--space-7)">
      <div class="mc-container">
        <Card radius="xl" pad="lg" elevation="lg" style="display:flex;justify-content:space-around;flex-wrap:wrap;gap:24px">
          {
            about.stats.map((s) => (
              <div data-gsap-child>
                <StatBlock value={s.value} label={s.label} />
              </div>
            ))
          }
        </Card>
      </div>
    </section>

    {/* Valores */}
    <section class="mc-section" style="background:var(--white)">
      <div class="mc-container">
        <div class="vals__head" data-gsap="fade-up">
          <Eyebrow align="center">{about.valores.eyebrow}</Eyebrow>
          <h2 class="vals__title">{about.valores.title}</h2>
        </div>
        <div class="vals__grid" data-gsap-group>
          {
            about.valores.items.map((v) => (
              <div data-gsap-child>
                <FeatureItem icon={`fa-solid ${v.icon}`} title={v.title} layout="stack">
                  {v.body}
                </FeatureItem>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <FinalCTA />
  </main>
</BaseLayout>

<script>
  import { initHomeChoreography } from '@lib/animations/choreography';
  initHomeChoreography();
</script>

<style>
  .mision {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  .mision__copy {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mision__title {
    margin: 0;
    font-size: var(--fs-h1);
    line-height: 1.12;
    color: var(--text-strong);
  }
  .mision__body {
    margin: 0;
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    color: var(--text-muted);
  }
  .mision__hl {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    color: var(--text-body);
  }
  .mision__media {
    max-width: 440px;
    margin-inline: auto;
  }
  .vals__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
  }
  .vals__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .vals__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  @media (max-width: 900px) {
    .mision {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .mision__media {
      order: -1;
    }
    .vals__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
