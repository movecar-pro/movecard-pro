---
/**
 * /precios — estructura del diseño:
 *   1+2. Hero + Planes FUSIONADOS en una sola sección (mismo fondo de streaks):
 *        título "Los planes más completos del mercado" + 4 planes en 2 grupos
 *        (tarjetas en desktop · acordeón single-open en móvil).
 *   3. ComoFuncionaSteps · 4. PreciosCompara · 5. Reaseguro · 6. FAQ · 7. Ayuda
 *   8. Simulador + FinalCTA.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ComoFuncionaSteps from '@components/sections/ComoFuncionaSteps.astro';
import PreciosCompara from '@components/sections/PreciosCompara.astro';
import Simulador from '@components/sections/Simulador.astro';
import FinalCTA from '@components/sections/FinalCTA.astro';
import Eyebrow from '@components/primitives/Eyebrow.astro';
import Button from '@components/primitives/Button.astro';
import FeatureItem from '@components/cards/FeatureItem.astro';
import PricingPlans from '@components/islands/PricingPlans.tsx';
import FaqAccordion from '@components/islands/FaqAccordion.tsx';
import { pricing } from '@lib/content';
import { faqCategories } from '@lib/faq';
---

<BaseLayout
  title="Precios y planes — Move Card Pro"
  description={pricing.header.subtitle}
  active="Precios / Planes"
>
  <main>
    {/* Sección 1+2 fusionadas: hero + planes sobre el mismo fondo de streaks */}
    <section class="pp-hero">
      <div class="pp-hero__head mc-container">
        <Eyebrow align="center" tone="dark" data-gsap="fade-up">{pricing.header.eyebrow}</Eyebrow>
        <h1 class="pp-hero__title" data-gsap="fade-up">{pricing.header.title}</h1>
        <p class="pp-hero__subtitle" data-gsap="fade-up">{pricing.header.subtitle}</p>
      </div>
      <div class="mc-container" data-gsap="fade-up">
        <PricingPlans client:visible groups={pricing.groups} />
      </div>
    </section>

    {/* Cómo Funciona (stepper → carrusel en móvil) */}
    <ComoFuncionaSteps />

    {/* Tabla comparativa */}
    <PreciosCompara />

    {/* Reaseguro: Rápido, Transparente y Seguro */}
    <section class="mc-section" style="background:var(--surface-subtle)">
      <div class="mc-container reassure">
        <div class="reassure__head" data-gsap="fade-up">
          <h2 class="reassure__title">{pricing.reassurance.title}</h2>
          <p class="reassure__body">{pricing.reassurance.body}</p>
        </div>
        <div class="reassure__grid" data-gsap-group>
          {
            pricing.reassurance.items.map((it) => (
              <div data-gsap-child>
                <FeatureItem icon={`fa-solid ${it.icon}`} title={it.title} layout="stack">
                  {it.body}
                </FeatureItem>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Preguntas Frecuentes — contenido completo, una sola abierta a la vez */}
    <section class="mc-section" style="background:var(--white)">
      <div class="mc-container" style="max-width:var(--content-max)">
        <div class="faq__head" data-gsap="fade-up">
          <Eyebrow align="center">Preguntas Frecuentes</Eyebrow>
          <h2 class="faq__title">Todo lo que necesitas saber</h2>
        </div>
        <div data-gsap="fade-up">
          <FaqAccordion client:visible categories={faqCategories} />
        </div>
      </div>
    </section>

    {/* ¿Todavía con dudas? */}
    <section style="background:var(--surface-subtle);padding-block:var(--space-7)">
      <div class="mc-container help" data-gsap="fade-up">
        <div>
          <h2 class="help__title">{pricing.help.title}</h2>
          <p class="help__body">{pricing.help.body}</p>
        </div>
        <Button href="#postular">{pricing.help.cta}</Button>
      </div>
    </section>

    {/* Simulador + CTA final (reutilizados) */}
    <Simulador />
    <FinalCTA />
  </main>
</BaseLayout>

<script>
  import { initHomeChoreography } from '@lib/animations/choreography';
  initHomeChoreography();
</script>

<style>
  /* Sección 1+2 fusionada (hero + planes) con fondo de streaks. */
  .pp-hero {
    position: relative;
    overflow: hidden;
    background:
      var(--surface-subtle) url('/assets/images/backgrounds/streak2a.svg') center top / cover
      no-repeat;
    padding-block: var(--space-section);
  }
  .pp-hero__head {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: var(--content-max);
    margin: 0 auto 56px;
  }
  .pp-hero__title {
    margin: 0;
    font-size: var(--fs-h1);
    line-height: 1.12;
    color: var(--text-strong);
  }
  .pp-hero__subtitle {
    margin: 0;
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    color: var(--text-muted);
  }

  .reassure__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: var(--content-max);
    margin: 0 auto 40px;
  }
  .reassure__title {
    margin: 0;
    font-size: var(--fs-h2);
    color: var(--text-strong);
  }
  .reassure__body {
    margin: 0;
    font-size: var(--fs-body-lg);
    color: var(--text-muted);
  }
  .reassure__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 960px;
    margin-inline: auto;
  }
  .faq__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 44px;
  }
  .faq__title {
    margin: 0;
    font-size: var(--fs-h1);
    color: var(--text-strong);
  }
  .help {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .help__title {
    margin: 0 0 4px;
    font-size: var(--fs-h4);
    color: var(--text-strong);
  }
  .help__body {
    margin: 0;
    font-size: var(--fs-body);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .reassure__grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 360px;
    }
  }
</style>
